generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Skin {
  id      Int     @id @default(autoincrement())
  name    String
  weapon  String
  rarity  String
  wear    String
  type    String
  image   String
  price   Float
}